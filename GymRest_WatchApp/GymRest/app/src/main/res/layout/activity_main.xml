<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Circular ring drawn behind everything -->
    <com.gymrest.RestRingView
        android:id="@+id/ring_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Center content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_boxedEdges="all">

        <!-- Status label -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aguardando"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:fontFamily="sans-serif-medium" />

        <!-- Timer / big number -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01:00"
            android:textColor="#FFFFFF"
            android:textSize="44sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="0.9" />

        <!-- Exercise name -->
        <TextView
            android:id="@+id/tv_exercise"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mova-se para detectar"
            android:textColor="#999999"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Sets counter -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:gap="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Séries:"
                android:textColor="#666666"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_sets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

    </LinearLayout>

    <!-- Manual button — bottom center -->
    <ImageButton
        android:id="@+id/btn_manual"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_circle_button"
        android:src="@drawable/ic_play"
        android:padding="10dp"
        android:contentDescription="Ação manual" />

</androidx.wear.widget.BoxInsetLayout>
